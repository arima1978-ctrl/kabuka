[Unit]
Description=Kabuka Telegram Bot (TSE Prime decliner ranking)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=skyuser
WorkingDirectory=/home/skyuser/kabuka
EnvironmentFile=/home/skyuser/kabuka/.env
ExecStart=/home/skyuser/kabuka/.venv/bin/python bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
